{
  "name": "codexa",
  "version": "1.0.1",
  "description": "Terminal UI for Codexa — TypeScript + Bun + Ink",
  "type": "module",
  "bin": {
    "codexa": "./bin/codexa.js"
  },
  "scripts": {
    "start": "bun run --silent src/index.tsx",
    "dev": "bun --watch --silent src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "ink-select-input": "^6.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
