{
  "name": "@golba98/codexa",
  "version": "1.0.7",
  "description": "Terminal UI for Codexa — TypeScript + Bun + Ink",
  "type": "module",
  "bin": {
    "codexa": "./bin/codexa.js"
  },
  "scripts": {
    "start": "bun run --silent src/index.tsx",
    "dev": "bun --watch --silent src/index.tsx",
    "dev:run": "node scripts/run-local-dev.mjs",
    "install:dev-bin": "node scripts/install-local-dev-bin.mjs",
    "debug:claude-models": "bun run --silent src/core/providerRuntime/claudeCodeDiscoveryDebug.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "audit:codexa-gap": "node scripts/audit-codexa-capabilities.mjs",
    "smoke:terminal-bench": "node scripts/smoke-terminal-bench.mjs",
    "gen-build-info": "node scripts/gen-build-info.mjs",
    "build": "bun run gen-build-info && bun run typecheck",
    "prepublishOnly": "npm run gen-build-info && npm run typecheck && npm test"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/golba98/Codexa.git"
  },
  "bugs": {
    "url": "https://github.com/golba98/Codexa/issues"
  },
  "homepage": "https://github.com/golba98/Codexa#readme",
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ]
}
